{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dr.Tools",
  "version": "0.1.4",
  "identifier": "com.west.drtools",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "width": 1240,
        "height": 840,
        "resizable": true,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/AppIcon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "python",
      "migrations"
    ]
  }
}
